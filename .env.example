# =====================================================================
# Environment variables required to run / deploy this app.
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real ".env" file to git.
# =====================================================================

# --- Supabase (from Project Settings -> API) ---
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"
SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_SUPABASE_PUBLISHABLE_KEY="YOUR_SUPABASE_ANON_KEY"

# --- Cloudflare Worker endpoints ---
VITE_GEN_WORKER_URL="https://your-generator-worker.workers.dev"
VITE_LICENSE_WORKER_URL="https://your-license-worker.workers.dev"

# --- Secure session cipher (MUST match the download-link generator worker) ---
VITE_CIPHER_KEY="your-cipher-key"

# --- Cloudflare Turnstile (bot protection) ---
VITE_TURNSTILE_SITE_KEY="your-turnstile-site-key"

# --- Firebase (legacy admin panel, if still used) ---
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_APP_ID="your-firebase-app-id"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_DB_URL="https://your-project-default-rtdb.firebaseio.com"
VITE_FIREBASE_PROJECT_ID="your-firebase-project-id"
